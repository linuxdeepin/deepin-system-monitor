//self
#include "process/am_icon_manager.h"

//gtest
#include "stub.h"
#include <gtest/gtest.h>

//qt
#include <DApplication>
#include <DSysInfo>
#include <QDBusReply>
#include <QDBusObjectPath>

using namespace core::process;
DCORE_USE_NAMESPACE

/***************************************STUB begin*********************************************/

// Mock DSysInfo::majorVersion() — source calls .toInt() on the return value
int g_mockMajorVersion = 25;
QString DSysInfo::majorVersion() {
    return QString::number(g_mockMajorVersion);
}

// Mock pidfd_open for testing without real pid
int g_mockPidfd = 3;
int g_pidfdOpenCallCount = 0;

int pidfd_open(pid_t pid, unsigned int flags) {
    g_pidfdOpenCallCount++;
    return g_mockPidfd;
}

/***************************************STUB end*********************************************/

class UT_AMIconManager : public ::testing::Test
{
public:
    UT_AMIconManager()
        : m_tester(nullptr) {}

public:
    virtual void SetUp()
    {
        g_mockMajorVersion = 25;
        g_mockPidfd = 3;
        g_pidfdOpenCallCount = 0;
        m_tester = new AMIconManager();
    }

    virtual void TearDown()
    {
        if (m_tester) {
            delete m_tester;
            m_tester = nullptr;
        }
        g_pidfdOpenCallCount = 0;
    }

protected:
    AMIconManager *m_tester;
};

TEST_F(UT_AMIconManager, TestGetInstance)
{
    auto *instance1 = AMIconManager::instance();
    auto *instance2 = AMIconManager::instance();
    EXPECT_EQ(instance1, instance2);
}

TEST_F(UT_AMIconManager, TestIsAMAvailable_PreV25)
{
    // Pre-V25: AM should not be available regardless of DBus state
    g_mockMajorVersion = 19;

    delete m_tester;
    m_tester = new AMIconManager();

    EXPECT_FALSE(m_tester->isAMAvailable());
}

TEST_F(UT_AMIconManager, TestGetIconByPid_PreV25)
{
    // Pre-V25: getIconByPid returns empty (AM not available)
    g_mockMajorVersion = 19;

    delete m_tester;
    m_tester = new AMIconManager();

    pid_t testPid = 9999;
    QString iconName = m_tester->getIconByPid(testPid);

    EXPECT_TRUE(iconName.isEmpty());
}

TEST_F(UT_AMIconManager, TestGetIconByPid_V25_NoAMService)
{
    // V25+ but AM DBus service is not registered in test environment
    g_mockMajorVersion = 25;

    delete m_tester;
    m_tester = new AMIconManager();

    // Without AM service, isAMAvailable is false and getIconByPid returns empty
    pid_t testPid = 1234;
    QString iconName = m_tester->getIconByPid(testPid);

    // AM service won't be running in unit test, so returns empty
    EXPECT_TRUE(iconName.isEmpty());
}

TEST_F(UT_AMIconManager, TestRemoveCachedIcon)
{
    // Remove non-existent cache entry — should not crash
    m_tester->removeCachedIcon(8888);
}

TEST_F(UT_AMIconManager, TestClearCache)
{
    // Clear empty cache — should not crash
    m_tester->clearCache();
}

TEST_F(UT_AMIconManager, TestGetProcessGroupInfo_PreV25)
{
    // Pre-V25: getProcessGroupInfo returns empty info
    g_mockMajorVersion = 19;

    delete m_tester;
    m_tester = new AMIconManager();

    AMProcessGroupInfo info = m_tester->getProcessGroupInfo(1234);
    EXPECT_FALSE(info.isValid());
    EXPECT_TRUE(info.appId.isEmpty());
    EXPECT_TRUE(info.instancePath.isEmpty());
    EXPECT_TRUE(info.iconName.isEmpty());
}

TEST_F(UT_AMIconManager, TestAMProcessGroupInfo_IsValid)
{
    AMProcessGroupInfo info;
    EXPECT_FALSE(info.isValid());

    info.appId = "test-app";
    EXPECT_FALSE(info.isValid());  // still missing instancePath

    info.instancePath = "/org/desktopspec/ApplicationManager1/test";
    EXPECT_TRUE(info.isValid());
}
